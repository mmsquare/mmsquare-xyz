---
<Base title="Writing — Ming Ma" description="Ming Ma's writing — observations on work, culture, and getting older in tech.">
  <h1>Writing</h1>
  <p>
    Mostly observations about work, culture, and navigating different worlds.
    Published on <a href="https://medium.com/@ming_ma" target="_blank">Medium</a>.
  </p>

  <hr />

  <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1.5rem;">
    {posts.map(post => (
      <div>
        <div class="muted" style="font-family: monospace; font-size: 0.8rem; margin-bottom: 0.2rem;">{post.date}</div>
        <a href={post.url} target="_blank" style="font-size: 1.05rem;">{post.title}</a>
        <div style="color: var(--muted); font-size: 0.9rem; margin-top: 0.1rem;">{post.subtitle}</div>
      </div>
    ))}
  </div>
</Base>
